{
  "compilerOptions": {
    "paths": {
      "@utility": ["./packages/utility/src/index.ts"],
      "@core": ["./packages/core/src/index.ts"],
      "@audiograph": ["./packages/audiograph/src/index.ts"],
      "@ast": ["./packages/ast/src/index.ts"],
      "@codecs": ["./packages/codecs/src/index.ts"],
      "@webaudio": ["./packages/webaudio/src/index.ts"],
      "@language": ["./packages/language/src/index.ts"],
      "@language-support": ["./packages/language-support/src/index.ts"],
      "@editor": ["./packages/editor/src/index.ts"],
      "@flowchart": ["./packages/flowchart/src/index.ts"]
    },
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ES2022",
    "target": "ES2022",
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "erasableSyntaxOnly": true,
    "strict": true,
    "esModuleInterop": true,
    "declaration": false,
    "outDir": "./dist",
    "noEmit": true,
    "jsx": "react-jsx",
    "skipLibCheck": true
  },
  "include": []
}
